<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ presentation_title }}</title>
  <style>
    :root {
      --bg: #f6f6f4;
      --fg: #111111;
      --muted: #4a4a4a;
      --accent: #0057ff;
      --accent-dim: rgba(0, 87, 255, 0.15);
      --line: #d8d8d4;
      --overlay: rgba(8, 8, 12, 0.68);
      --font: "Segoe UI", system-ui, -apple-system, sans-serif;
      --bar-h: 72px;
      --demo-head-h: 10vh;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      font-family: var(--font);
      background: #000;
      color: var(--fg);
      user-select: none;
    }

    #deck {
      position: relative;
      width: 100vw;
      height: 100vh;
      overflow: hidden;
    }

    .slide {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.35s ease;
    }

    .slide.active {
      opacity: 1;
      pointer-events: auto;
      z-index: 2;
    }

    /* —— шапка проекта + шаги —— */
    .talk-header {
      flex: 0 0 auto;
      padding: 1.4vh 3.5vw 1.1vh;
      border-bottom: 4px solid var(--fg);
      background: var(--bg);
    }

    .talk-identity {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.35em 1.5em;
    }

    .project-title {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 0.35em 0.5em;
      font-size: clamp(28px, 4vw, 56px);
      font-weight: 900;
      line-height: 1.05;
      letter-spacing: -0.02em;
      flex: 1 1 auto;
      min-width: 0;
    }

    .project-author {
      font-size: clamp(18px, 2.1vw, 32px);
      font-weight: 600;
      color: var(--muted);
      white-space: nowrap;
      flex: 0 0 auto;
    }

    .talk-step {
      font-size: 0.72em;
      font-weight: 800;
      color: var(--muted);
      letter-spacing: 0.01em;
      white-space: nowrap;
    }

    /* —— контентные слайды —— */
    .slide.content {
      background: var(--bg);
    }

    .slide-body {
      flex: 1 1 auto;
      min-height: 0;
      padding: 1.6vh 3.5vw 11vh;
      overflow: auto;
      font-size: clamp(20px, 2.1vw, 32px);
      line-height: 1.45;
      max-width: 1280px;
    }

    .slide-body ul, .slide-body ol { margin: 0.6em 0 0.6em 1.2em; }
    .slide-body li { margin: 0.35em 0; }
    .slide-body p { margin: 0.5em 0; }
    .slide-body strong { font-weight: 800; }

    .slide-body img,
    .slide-body svg {
      display: block;
      max-width: min(96vw, 1100px);
      max-height: 58vh;
      margin: 0.8em auto;
      border: 2px solid var(--fg);
      background: #fff;
    }

    .slide-body table { border-collapse: collapse; margin: 1em 0; font-size: 0.85em; }
    .slide-body th, .slide-body td { border: 2px solid var(--fg); padding: 0.45em 0.75em; }
    .slide-body th { background: var(--fg); color: var(--bg); }

    /* —— демо (тот же светлый стиль, что и content) —— */
    .slide.demo {
      background: var(--bg);
      color: var(--fg);
    }

    .demo-body {
      flex: 1 1 auto;
      min-height: 0;
      display: flex;
      flex-direction: column;
      padding: 1vh 3.5vw 11vh;
      max-width: 100%;
    }

    .demo-intro {
      flex: 0 0 auto;
      color: var(--muted);
      font-size: clamp(17px, 1.75vw, 26px);
      line-height: 1.35;
      margin-bottom: 0.8vh;
      max-height: 10vh;
      overflow: hidden;
    }

    .demo-intro:empty { display: none; }

    .demo-intro p { margin: 0.35em 0; }

    .demo-media {
      flex: 1 1 0;
      min-height: 0;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .demo-media img,
    .demo-media video {
      display: block;
      width: 100%;
      height: 100%;
      max-width: min(96vw, 1280px);
      max-height: calc(100vh - var(--bar-h) - var(--demo-head-h) - 2vh);
      object-fit: contain;
      object-position: center center;
      border: 2px solid var(--fg);
      background: #fff;
    }

    /* —— welcome / questions —— */
    .slide.cinematic {
      color: #fff;
      align-items: stretch;
      justify-content: flex-start;
    }

    .bg-video-stack {
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
      background: #000;
    }

    .bg-video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      z-index: 0;
      transition: none;
      pointer-events: none;
    }

    /* нижний слой — всегда на полной яркости */
    .bg-video.is-base {
      opacity: 1;
      z-index: 1;
    }

    /* верхний слой — только проявление 0→1, без затухания нижнего */
    .bg-video.is-overlay {
      z-index: 2;
      opacity: 0;
      transition: opacity 1s ease-in-out;
      will-change: opacity;
    }

    .bg-video.is-overlay.reveal {
      opacity: 1;
    }

    .cinematic-banner {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      z-index: 2;
      background: rgba(8, 8, 14, 0.78);
      border-bottom: 3px solid rgba(255, 255, 255, 0.15);
      padding: 2.2vh 5vw 2.4vh;
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center;
    }

    .cinematic-content {
      max-width: 1100px;
      width: 100%;
      margin: 0 auto;
      text-align: center;
    }

    .cinematic h1 {
      font-size: clamp(32px, 5vw, 72px);
      font-weight: 900;
      line-height: 1.08;
      margin-bottom: 0.2em;
    }

    .cinematic .subtitle {
      font-size: clamp(18px, 2.2vw, 32px);
      font-weight: 500;
      color: #e8e8e8;
    }

    .hint {
      position: fixed;
      bottom: 58px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 20;
      font-size: 12px;
      color: rgba(255, 255, 255, 0.45);
      pointer-events: none;
    }

    #progress-bar {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 30;
      background: rgba(0, 0, 0, 0.9);
      color: #fff;
      padding: 8px 18px 10px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      height: var(--bar-h);
      justify-content: center;
    }

    #progress-track {
      width: 100%;
      height: 5px;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 3px;
      overflow: hidden;
    }

    #progress-fill {
      height: 100%;
      width: 0%;
      background: var(--accent);
      transition: width 0.3s ease;
    }

    #progress-meta {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-size: 13px;
      font-weight: 600;
    }

    #progress-label { color: #ccc; }
    #progress-count { color: #fff; font-variant-numeric: tabular-nums; }

  </style>
</head>
<body>
  <div id="deck" aria-live="polite"></div>
  <div class="hint">Колесо / стрелки · F11</div>

  <div id="progress-bar">
    <div id="progress-track"><div id="progress-fill"></div></div>
    <div id="progress-meta">
      <span id="progress-label">—</span>
      <span id="progress-count">0 / 0</span>
    </div>
  </div>

  <script>
    const SLIDES = {{ slides_json | safe }};

    const deck = document.getElementById('deck');
    const progressFill = document.getElementById('progress-fill');
    const progressLabel = document.getElementById('progress-label');
    const progressCount = document.getElementById('progress-count');

    let index = 0;
    let wheelLocked = false;
    const BG_CROSSFADE_MS = 1000;

    function escapeHtml(s) {
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function renderTalkHeader(data, sectionTitle) {
      const author = data.author
        ? `<p class="project-author">${escapeHtml(data.author)}</p>`
        : '';
      const step = sectionTitle
        ? `<span class="talk-step">[${escapeHtml(sectionTitle.toLowerCase())}]</span>`
        : '';
      return `
        <header class="talk-header">
          <div class="talk-identity">
            <h1 class="project-title">
              <span>${escapeHtml(data.block_title || '')}</span>
              ${step}
            </h1>
            ${author}
          </div>
        </header>
      `;
    }

    function renderSlide(data, i) {
      const el = document.createElement('section');
      el.className = 'slide';
      el.dataset.index = String(i);

      if (data.type === 'welcome' || data.type === 'questions') {
        el.classList.add('cinematic');
        el.innerHTML = `
          <div class="bg-video-stack" aria-hidden="true">
            <video class="bg-video bg-video-a" muted playsinline preload="auto"></video>
            <video class="bg-video bg-video-b" muted playsinline preload="auto"></video>
          </div>
          <div class="cinematic-banner">
            <div class="cinematic-content cinematic">
              <h1>${escapeHtml(data.title || '')}</h1>
              ${data.subtitle ? `<p class="subtitle">${escapeHtml(data.subtitle)}</p>` : ''}
            </div>
          </div>
        `;
        el.dataset.videos = JSON.stringify(data.videos || []);
        return el;
      }

      if (data.type === 'demo') {
        el.classList.add('demo');
        const media = data.mime === 'video'
          ? `<video src="${data.src}" controls playsinline preload="metadata"></video>`
          : data.mime === 'image'
            ? `<img src="${data.src}" alt="Демо ${data.index}">`
            : `<p>Нет медиа</p>`;
        const demoTitle = data.total > 1
          ? `Демо ${data.index} / ${data.total}`
          : 'Демо';
        el.innerHTML = `
          ${renderTalkHeader(data, demoTitle)}
          <div class="slide-body demo-body">
            <div class="demo-intro">${data.intro_html || ''}</div>
            <div class="demo-media">${media}</div>
          </div>
        `;
        return el;
      }

      el.classList.add('content');
      el.innerHTML = `
        ${renderTalkHeader(data, data.section_title || '')}
        <div class="slide-body">${data.html || ''}</div>
      `;
      return el;
    }

    function buildDeck() {
      SLIDES.forEach((s, i) => deck.appendChild(renderSlide(s, i)));
    }

    function stopBgVideo() {
      deck.querySelectorAll('.slide.cinematic').forEach((slide) => {
        if (typeof slide._bgStop === 'function') slide._bgStop();
      });
    }

    function startBgRotation(slideEl) {
      stopBgVideo();
      const raw = slideEl.dataset.videos;
      if (!raw) return;
      const urls = JSON.parse(raw);
      if (!urls.length) return;

      const stack = slideEl.querySelector('.bg-video-stack');
      const layers = stack ? Array.from(stack.querySelectorAll('.bg-video')) : [];
      if (layers.length < 2) return;

      let front = 0;
      let back = 1;
      let currentIdx = Math.floor(Math.random() * urls.length);
      let transitioning = false;
      let stopped = false;

      function resetLayerClasses(v) {
        v.classList.remove('is-base', 'is-overlay', 'reveal', 'visible');
      }

      layers.forEach((v) => {
        v.muted = true;
        v.playsInline = true;
        v.loop = false;
        v.preload = 'auto';
        resetLayerClasses(v);
      });

      function pickNextIdx() {
        if (urls.length === 1) return 0;
        let next;
        do {
          next = Math.floor(Math.random() * urls.length);
        } while (next === currentIdx);
        return next;
      }

      function waitReady(video) {
        return new Promise((resolve) => {
          if (video.readyState >= 4) {
            resolve();
            return;
          }
          const done = () => {
            video.removeEventListener('canplaythrough', done);
            video.removeEventListener('canplay', done);
            video.removeEventListener('error', done);
            resolve();
          };
          video.addEventListener('canplaythrough', done);
          video.addEventListener('canplay', done);
          video.addEventListener('error', done);
        });
      }

      function loadInto(video, idx) {
        const url = urls[idx];
        if (video.dataset.src !== url) {
          video.dataset.src = url;
          video.src = url;
          video.load();
        } else {
          video.currentTime = 0;
        }
        return waitReady(video).then(() => video.play().catch(() => {}));
      }

      function revealOverlay(overlayEl) {
        overlayEl.classList.add('is-overlay');
        overlayEl.classList.remove('reveal');
        void overlayEl.offsetWidth;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => overlayEl.classList.add('reveal'));
        });
      }

      function bindAdvanceHandlers(active) {
        active.onended = () => crossfadeToNext();
        active.ontimeupdate = () => {
          const dur = active.duration;
          if (!dur || dur < 2) return;
          if (active.currentTime >= dur - 1.2) {
            active.ontimeupdate = null;
            crossfadeToNext();
          }
        };
      }

      async function crossfadeToNext() {
        if (stopped || transitioning) return;
        transitioning = true;

        const frontEl = layers[front];
        const backEl = layers[back];
        const nextIdx = pickNextIdx();

        frontEl.onended = null;
        frontEl.ontimeupdate = null;

        resetLayerClasses(backEl);
        await loadInto(backEl, nextIdx);
        if (stopped) {
          transitioning = false;
          return;
        }

        /* нижний слой остаётся на 100% — верхний плавно накрывает */
        revealOverlay(backEl);

        window.setTimeout(() => {
          if (stopped) return;
          resetLayerClasses(frontEl);
          frontEl.pause();
          frontEl.removeAttribute('src');
          delete frontEl.dataset.src;
          frontEl.load();

          resetLayerClasses(backEl);
          backEl.classList.add('is-base');

          currentIdx = nextIdx;
          [front, back] = [back, front];
          bindAdvanceHandlers(layers[front]);
          transitioning = false;
        }, BG_CROSSFADE_MS + 50);
      }

      slideEl._bgStop = () => {
        stopped = true;
        layers.forEach((v) => {
          v.onended = null;
          v.ontimeupdate = null;
          v.pause();
          v.removeAttribute('src');
          delete v.dataset.src;
          resetLayerClasses(v);
          v.load();
        });
        delete slideEl._bgStop;
      };

      (async () => {
        const first = layers[0];
        await loadInto(first, currentIdx);
        if (stopped) return;
        first.classList.add('is-base');
        bindAdvanceHandlers(first);
      })();
    }

    function pauseInactiveMedia() {
      deck.querySelectorAll('video').forEach(v => {
        if (!v.classList.contains('bg-video')) v.pause();
      });
    }

    function pauseDemoVideos(slideEl) {
      slideEl.querySelectorAll('.demo-media video').forEach((v) => {
        v.pause();
      });
    }

    function updateUI() {
      const nodes = deck.querySelectorAll('.slide');
      nodes.forEach((n, i) => n.classList.toggle('active', i === index));

      const current = SLIDES[index] || {};
      stopBgVideo();

      const activeEl = nodes[index];
      if (activeEl) {
        if (current.type === 'welcome' || current.type === 'questions') {
          startBgRotation(activeEl);
        } else if (current.type === 'demo') {
          pauseDemoVideos(activeEl);
        }
      }

      const total = SLIDES.length;
      progressFill.style.width = (total ? ((index + 1) / total) * 100 : 0) + '%';

      let label = current.block_title || current.title || 'Выступление';
      if (current.section_title) label += ' — ' + current.section_title;
      if (current.type === 'demo') label += ' · демо ' + current.index;
      progressLabel.textContent = label;
      progressCount.textContent = (index + 1) + ' / ' + total;
    }

    function go(delta) {
      const next = index + delta;
      if (next < 0 || next >= SLIDES.length) return;
      pauseInactiveMedia();
      index = next;
      updateUI();
    }

    document.addEventListener('wheel', (e) => {
      if (Math.abs(e.deltaY) < 8) return;
      e.preventDefault();
      if (wheelLocked) return;
      wheelLocked = true;
      setTimeout(() => { wheelLocked = false; }, 380);
      go(e.deltaY > 0 ? 1 : -1);
    }, { passive: false });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === 'PageDown' || e.key === ' ') {
        e.preventDefault();
        go(1);
      }
      if (e.key === 'ArrowLeft' || e.key === 'PageUp') {
        e.preventDefault();
        go(-1);
      }
      if (e.key === 'Home') { index = 0; updateUI(); }
      if (e.key === 'End') { index = SLIDES.length - 1; updateUI(); }
    });

    buildDeck();
    updateUI();
  </script>
</body>
</html>
